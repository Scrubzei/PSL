# ── Server configuration ──────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# never commit real secrets.

# Runtime
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=appdb

# Auth
JWT_SECRET=change-me
JWT_EXPIRATION=7d

# Discord OAuth / bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
DISCORD_GUILD_ID=
DISCORD_BOT_TOKEN=

# Bot integration
BOT_API_KEY=
BOTZEI_URL=

# NeatQueue — powers the dashboard "Live Activity" feed.
# Token from the NeatQueue dashboard; server id is the Discord guild id.
NEATQUEUE_API_TOKEN=
NEATQUEUE_SERVER_ID=

# Match report deadlines (hours)
MATCH_REPORT_DEADLINE_XP_HOURS=48
MATCH_REPORT_DEADLINE_RANKED_HOURS=24

# Tournaments
TOURNAMENT_PARTICIPANTS=
