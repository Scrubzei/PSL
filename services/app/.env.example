# API Configuration
# Base URL for the API endpoint
API_BASE_URL=https://api.1v1lb.com

# Discord Configuration
# Discord bot token for reporting detections
# Get your token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord channel ID where detections will be reported
# Right-click on a Discord channel and select "Copy Channel ID" (Developer Mode must be enabled)
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Discord OAuth2 Client ID for user authentication
# Get your Client ID from https://discord.com/developers/applications
# Go to OAuth2 tab and copy the Client ID (no Client Secret needed with PKCE)
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord Guild (Server) ID that users must join
# Right-click on your Discord server and select "Copy Server ID" (Developer Mode must be enabled)
DISCORD_GUILD_ID=your_discord_guild_id_here

# Discord Invite Link for users to join the required server
# Create a permanent invite link in your Discord server
# Format: https://discord.gg/xxxxx or https://discord.com/invite/xxxxx
DISCORD_INVITE_LINK=your_discord_invite_link_here

# Anti-Cheat Settings
# Enable or disable the anti-cheat system (true/false)
ANTI_CHEAT_ENABLED=true

# Scan interval in seconds (how often to scan for cheats)
# Lower values = more frequent scans but higher CPU usage
# Recommended: 15 seconds or higher
SCAN_INTERVAL_SECONDS=15
